<div class="min-h-screen flex flex-col font-sans bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-slate-100">
    <!-- Header component: lazy loaded -->
    {% if has_template("header.j2") %}
        {% include "header.j2" %}
    {% else %}
        {{ placeholder("header.j2") }}
    {% endif %}

    <!-- App container -->
    <div class="flex-1 max-w-7xl w-full mx-auto flex gap-6 px-4 md:px-8 py-8">
        <!-- Sidebar Navigation: lazy loaded -->
        <aside class="hidden md:block w-64 shrink-0">
            <div class="sticky top-24">
                {% if has_template("sidebar.j2") %}
                    {% include "sidebar.j2" %}
                {% else %}
                    {{ placeholder("sidebar.j2") }}
                {% endif %}
            </div>
        </aside>

        <!-- Main Document Area -->
        <article class="flex-1 min-w-0 prose prose-slate dark:prose-invert max-w-none">
            <div class="mb-3 text-xs font-semibold text-indigo-600 dark:text-indigo-400 tracking-wide uppercase">
                {{ meta.category if meta.category else "Documentation" }}
            </div>
            
            <h1 class="text-4xl font-extrabold tracking-tight mb-2 text-slate-900 dark:text-white">
                {{ meta.title if meta.title else "Untitled Document" }}
            </h1>
            
            <div class="flex flex-wrap items-center gap-3 text-xs text-slate-500 mb-8 border-b border-slate-200/60 dark:border-slate-800 pb-4">
                <span>"Updated: " {{ meta.date if meta.date else "2026-07-06" }}</span>
                <span>•</span>
                <span>"Language: " <span class="uppercase font-semibold text-cyan-600 dark:text-cyan-400">{{ lang }}</span></span>
                {% if meta.tags %}
                    <span>•</span>
                    {% for tag in meta.tags %}
                        <span class="px-2 py-0.5 rounded-full bg-slate-200/50 dark:bg-slate-800 text-slate-600 dark:text-slate-400 font-medium">#{{ tag }}</span>
                    {% endfor %}
                {% endif %}
            </div>

            <!-- Compiled Markdown Body -->
            <div class="markdown-body leading-7 text-slate-700 dark:text-slate-300">
                {{ content | safe }}
            </div>
        </article>

        <!-- Table of Contents sidebar: lazy loaded -->
        <aside class="hidden lg:block w-48 shrink-0">
            <div class="sticky top-24">
                {% if has_template("toc.j2") %}
                    {% include "toc.j2" %}
                {% else %}
                    {{ placeholder("toc.j2") }}
                {% endif %}
            </div>
        </aside>
    </div>
</div>
